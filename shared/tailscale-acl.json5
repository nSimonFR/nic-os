// Tailscale tailnet policy file (HuJSON syntax, named .json5 for
// github native highlighting; the gitops-acl action reads it via
// the explicit `path:` input regardless of extension).
// Synced to https://login.tailscale.com/admin/acls/file by
// .github/workflows/tailscale-acl.yml on push to main.
{
	"acls": [
		{
			"action": "accept",
			"src":    ["autogroup:member"],
			"dst":    ["autogroup:member:*"],
		},
		{
			"action": "accept",
			"src":    ["autogroup:member"],
			"dst":    ["10.7.0.1/32:*", "34.117.84.152/32:*"],
		},
		{
			// SideStore reflector return path. The rpi5 reflector rewrites the
			// phone's 10.7.0.1 packets to appear sourced FROM 10.7.0.1 (StosVPN's
			// swap), so the reflected SYN-ACK reaches the phone as a connection
			// from 10.7.0.1. Without this rule Tailscale's stateful filter drops
			// it (the swap's ports don't match the outbound flow's return tuple),
			// so the handshake never completes.
			"action": "accept",
			"src":    ["10.7.0.1/32"],
			"dst":    ["autogroup:member:*"],
		},
	],
	"grants": [
		{
			"src": ["*"],
			"dst": ["*"],
			"app": {
				"tailscale.com/cap/drive": [
					{"shares": ["*"], "access": "rw"},
				],
			},
		},
		{
			"src": ["autogroup:member"],
			"dst": ["autogroup:internet"],
			"ip":  ["*"],
		},
	],
	"ssh": [
		{
			"action":      "check",
			"src":         ["autogroup:member"],
			"dst":         ["autogroup:self"],
			"users":       ["autogroup:nonroot", "root"],
			"checkPeriod": "168h",
		},
	],
	"nodeAttrs": [
		{
			"target": ["autogroup:member"],
			"attr":   ["funnel", "drive:share", "drive:access", "exit-node"],
		},
	],
	"autoApprovers": {
		"exitNode": ["autogroup:member"],
		// 10.7.0.1/32 is SideStore's fixed virtual-computer address, advertised
		// by rpi5 so the tailnet-connected phone can refresh with no on-device VPN.
		"routes": {
			"10.7.0.1/32": ["autogroup:member"],
		},
	},
}
