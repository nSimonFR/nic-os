{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_BASE_URL": "https://ai.gate-mintaka.ts.net"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Task(*)",
      "Monitor(*)",
      "Monitor",
      "Skill",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "PushNotification",
      "ScheduleWakeup",
      "SendUserFile",
      "CronCreate",
      "CronList",
      "CronDelete",
      "mcp__claude_ai_Figma__get_screenshot",
      "mcp__claude_ai_Figma__get_metadata",
      "mcp__claude_ai_Figma__get_variable_defs",
      "mcp__claude_ai_Figma__get_design_context",
      "mcp__claude_ai_Figma__get_code_connect_map",
      "mcp__claude_ai_Figma__get_context_for_code_connect",
      "mcp__claude_ai_Figma__get_code_connect_suggestions",
      "mcp__claude_ai_Figma__download_assets",
      "mcp__claude_ai_Figma__get_figjam",
      "mcp__claude_ai_Figma__get_libraries",
      "mcp__claude_ai_Figma__search_design_system",
      "mcp__claude_ai_Figma__whoami",
      "mcp__claude_ai_Asana",
      "mcp__claude_ai_Atlassian",
      "mcp__claude_ai_Balsamiq",
      "mcp__claude_ai_Box",
      "mcp__claude_ai_Canva",
      "mcp__claude_ai_Figma",
      "mcp__claude_ai_Gmail",
      "mcp__claude_ai_Google_Calendar",
      "mcp__claude_ai_Google_Drive",
      "mcp__claude_ai_HubSpot",
      "mcp__claude_ai_Intercom",
      "mcp__claude_ai_Linear",
      "mcp__claude_ai_monday_com",
      "mcp__claude_ai_Notion",
      "mcp__claude_ai_Slack",
      "mcp__claude_ai_Slite",
      "mcp__ide",
      "mcp__plugin_slack_slack",
      "mcp__Linear",
      "mcp__Miro",
      "mcp__metabase",
      "mcp__trusk-steampipe",
      "mcp__toolhive-tech"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/.venv/**)",
      "Read(**/venv/**)",
      "Read(**/vendor/**)",
      "Read(**/.pnp.*)",
      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/pnpm-lock.yaml)",
      "Read(**/bun.lockb)",
      "Read(**/Cargo.lock)",
      "Read(**/poetry.lock)",
      "Read(**/Pipfile.lock)",
      "Read(**/composer.lock)",
      "Read(**/flake.lock)",
      "Read(**/Gemfile.lock)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/.next/**)",
      "Read(**/out/**)",
      "Read(**/target/**)",
      "Read(**/coverage/**)",
      "Read(**/.turbo/**)",
      "Read(**/.nuxt/**)",
      "Read(**/.svelte-kit/**)",
      "Read(**/*.min.js)",
      "Read(**/*.min.css)",
      "Read(**/*.map)",
      "Read(**/.cache/**)",
      "Read(**/__pycache__/**)",
      "Read(**/*.pyc)",
      "Read(**/.pytest_cache/**)",
      "Read(**/.mypy_cache/**)",
      "Read(**/*.log)",
      "Read(**/npm-debug.log*)",
      "Read(**/*.png)",
      "Read(**/*.jpg)",
      "Read(**/*.jpeg)",
      "Read(**/*.gif)",
      "Read(**/*.webp)",
      "Read(**/*.ico)",
      "Read(**/*.pdf)",
      "Read(**/*.woff)",
      "Read(**/*.woff2)",
      "Read(**/*.ttf)",
      "Read(**/*.zip)",
      "Read(**/*.tar.gz)",
      "Read(**/*.mp4)",
      "Read(**/*.enc)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)"
    ],
    "_comment_deny": "Global token-saving Read denials (home-manager managed via nic-os/home/dotfiles/claude-settings.json, wired to ~/.claude/settings.json in home/claude.nix). permissions.deny Read() rules are Claude Code's real file-exclusion mechanism — .claudeignore is NOT a native feature. Rules follow gitignore semantics and apply to Read/Grep/Glob plus cat/head/tail/sed in Bash, across every project (user-level settings = global). Unanchored patterns (no // or ~ prefix) match at any depth. Conservative: dependencies, lockfiles, build output, minified/maps, caches, logs, binaries/media, and secrets only — never real source code. Secrets entries (*.enc/*.pem/*.key/*.p12) also cover sops-encrypted Trusk deployment/configurations/<env>/secrets/ payloads. Edit to extend; deny merges across scopes and a deny at any level wins."
  },
  "deniedMcpServers": [
    {
      "serverName": "claude-in-chrome"
    }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/claude-notify notification",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/claude-notify activity",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "PushNotification",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/claude-notify push",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/memory-sync",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/bash-history",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/wakatime",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "mattpocock-skills@mattpocock": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "mattpocock": {
      "source": {
        "source": "github",
        "repo": "mattpocock/skills"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "trustAll": true
}
