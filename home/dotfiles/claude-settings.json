{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Task(*)"
    ],
    "deny": []
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/telegram-notify",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/notification.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/session_start.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/user_prompt_submit.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/pre_tool_use.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/post_tool_use.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/stop.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/subagent_stop.sh\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/permission_request.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing/hooks/session_end.sh\""
          }
        ]
      }
    ]
  },
  "env": {
    "PHOENIX_ENDPOINT": "https://app.phoenix.arize.com/s/nsimon",
    "ARIZE_TRACE_ENABLED": "true",
    "CLAUDE_PLUGIN_ROOT": "/Users/nsimon/.claude/plugins/marketplaces/arize-claude-plugin/plugins/claude-code-tracing"
  },
  "effortLevel": "medium",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "trustAll": true
}
